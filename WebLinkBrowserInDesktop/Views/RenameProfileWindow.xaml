<Window x:Class="WebLinkBrowserInDesktop.Views.RenameProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        Title="Change profile name" Height="150" Width="300" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="15">
        <StackPanel>
            <TextBlock Text="New Name Profile:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtNewName" Height="25" VerticalContentAlignment="Center"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="Save" Width="80" Height="30" Click="Save_Click" Margin="0,0,10,0"/>
            <Button Content="Cancel" Width="80" Height="30" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
