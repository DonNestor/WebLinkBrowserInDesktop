<Window x:Class="WebLinkBrowserInDesktop.Views.AddLinkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add new link" Height="220" Width="400" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="15">
        <StackPanel>
            <TextBlock Text="Name:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtLinkName" Height="25" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

            <TextBlock Text="URL:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtLinkUrl" Height="25" VerticalContentAlignment="Center"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="Save" Width="80" Height="30" Click="Save_Click" Margin="0,0,10,0"/>
            <Button Content="Cancel" Width="80" Height="30" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>