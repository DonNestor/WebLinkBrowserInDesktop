<Window x:Class="WebLinkBrowserInDesktop.Views.LinkEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WebLinkBrowserInDesktop.Views"
        mc:Ignorable="d"
        Title="Edycja linku" Height="450" Width="800" WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <StackPanel>
            <Label Content="Nazwa strony: " />
            <TextBox x:Name="txtName" Margin="0,0,0,10"/>

            <Label Content="URL: " />
            <TextBox x:Name="txtUrl" Margin="0,0,0,10"/>

            <Label Content="Przeglądarka: " />
            <ComboBox x:Name="cbx" Margin="0,0,0,15">
                <ComboBoxItem Content="Chrome"/>
                <ComboBoxItem Content="Opera"/>
                <ComboBoxItem Content="FireFox"/>
                <ComboBoxItem Content="Tor"/>
            </ComboBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Zapisz" Click="Save_Click" Width="80" Margin="5.0"/>
                <Button Content="Anuluj" Click="Cancel_Click" Width="80" Margin="5.0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
