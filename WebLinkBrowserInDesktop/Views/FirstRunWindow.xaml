<Window x:Class="WebLinkBrowserInDesktop.Views.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Konfiguracja Bazy" Height="200" Width="400" WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20" VerticalAlignment="Center">
        <TextBlock Text="Witaj! Nie znaleziono bazy danych." FontSize="16" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
        <TextBlock Text="Wybierz co chcesz zrobić:" Margin="0,0,0,20" HorizontalAlignment="Center"/>

        <Button Content="Utwórz nową bazę danych" Margin="5" Click="CreateNewDb_Click"/>
        <Button Content="Wczytaj istniejącą bazę (.db)" Margin="5" Click="LoadExistingDb_Click"/>
    </StackPanel>
</Window>