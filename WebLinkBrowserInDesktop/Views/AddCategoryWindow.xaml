<Window x:Class="WebLinkBrowserInDesktop.Views.AddCategoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Category" Height="200" Width="350" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="15">
        <StackPanel>
            <TextBlock x:Name="txtParentInfo" Text="Add main category" Foreground="Gray" FontSize="11" Margin="0,0,0,15"/>

            <TextBlock Text="New category name:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtCategoryName" Height="25" VerticalContentAlignment="Center"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="Save" Width="80" Height="30" Click="Save_Click" Margin="0,0,10,0"/>
            <Button Content="Cancel" Width="80" Height="30" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>