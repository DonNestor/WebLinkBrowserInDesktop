<Window x:Class="WebLinkBrowserInDesktop.Views.EditProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Profile" Height="250" Width="450" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Top">
            <TextBlock Text="Profile name:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtProfileName" Height="25" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

            <TextBlock Text="Connected database:" FontWeight="Bold" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBox x:Name="txtDbPath" Width="300" Height="25" IsReadOnly="True" Background="#F0F0F0" VerticalContentAlignment="Center"/>
                <Button Content="Change..." Width="70" Height="25" Margin="5,0,0,0" Click="ChangeDb_Click"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="Save" Width="100" Height="30" Click="Save_Click" Margin="5,0"/>
            <Button Content="Cancel" Width="80" Height="30" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
