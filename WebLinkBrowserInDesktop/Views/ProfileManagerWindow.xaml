<Window x:Class="WebLinkBrowserInDesktop.Views.ProfileManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Profile" Height="300" Width="400" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Select an existing profile or create a new one:" FontWeight="Bold" Margin="0,0,0,10"/>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="lstProfiles" Grid.Column="0" DisplayMemberPath="Name" SelectedValuePath="FullPath" Margin="0,0,10,0"/>

            <StackPanel Grid.Column="1" VerticalAlignment="Top">
                <Button Content="Edit name" Height="25" Margin="0,0,0,5" Click="RenameProfile_Click"/>
                <Button Content="Delete profile" Height="25" Foreground="Red" Click="DeleteProfile_Click"/>
            </StackPanel>
        </Grid>
        
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <CheckBox x:Name="chkRememberProfile" Content="Remember this profile" VerticalAlignment="Center" Grid.Column="0" />

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Create New..." Width="100" Height="30" Click="CreateNew_Click" Margin="0,0,10,0"/>
                <Button Content="Load Selected" Width="100" Height="30" Click="LoadSelected_Click" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>