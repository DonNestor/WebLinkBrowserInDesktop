<Window x:Class="WebLinkBrowserInDesktop.Views.ProfileManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Profile Manager" Height="300" Width="400" WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Profiles">
            <ListBox x:Name="ProfilesListBox" d:ItemsSource="{d:SampleData ItemCount=5}"/>
        </GroupBox>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="New" Width="70" Click="NewProfile_Click" Margin="5,0"/>
            <Button Content="Edytuj" Width="70" Height="30" Margin="5,0" Click="EditProfile_Click"/>
            <Button Content="Delete" Width="70" Click="DeleteProfile_Click" Margin="5,0" Background="#FFFFEBEB"/>
            <Separator Width="20" Visibility="Hidden"/>
            <Button Content="Load" Width="80" Click="LoadProfile_Click" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>