<Window x:Class="WebLinkBrowserInDesktop.Views.NewProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create new profile" Height="250" Width="400" WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20" VerticalAlignment="Center">
        <TextBlock Text="Hello! Create a new profile." FontSize="16" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
        <TextBlock Text="Enter a name of the new profile" FontSize="12" FontWeight="Bold" Margin="0,0,0,5" />
        <TextBox x:Name="txtProfileName" Height="30" VerticalAlignment="Center"/>

        <TextBlock Text="Database source:" FontWeight="Bold" Margin="0,0,0,5" >
            <RadioButton x:Name="rbEmptyDb" Content="Create empty database" IsChecked="True" Margin="0,0,0,5" Checked="DbSource_Changed"/>
            <RadioButton x:Name="rbExistingDb" Content="Import existing database" Margin="0,0,0,5" Checked="DbSource_Changed"/>
        </TextBlock>

        <StackPanel x:Name="pnlExistingDb" Orientation="Horizontal" Margin="20,5,0,20" Visibility="Collapsed">
            <TextBox x:Name="txtExistingDbPath" Width="220" Height="25" IsReadOnly="True" Background="#F0F0F0" VerticalContentAlignment="Center"/>
            <Button Content="Choose..." Width="70" Height="25" Margin="5,0,0,0" Click="BrowseExistingDb_Click"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="Create" Width="80" Height="30" Click="Create_Click" Margin="5,0"/>
            <Button Content="Cancel" Width="80" Height="30" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>