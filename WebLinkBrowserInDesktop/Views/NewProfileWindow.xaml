<Window x:Class="WebLinkBrowserInDesktop.Views.NewProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create new profile" Height="200" Width="400" WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20" VerticalAlignment="Center">
        <TextBlock Text="Hello! Create a new profile." FontSize="16" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
        <TextBlock Text="Enter a name of the new profile" FontSize="12" FontWeight="Bold" Margin="0,0,0,5" />
        <TextBox x:Name="txtProfileName" Height="30" VerticalAlignment="Center"/>

        <TextBlock Text="A new, empty database will be created." Foreground="Gray" FontSize="11" Margin="0,5,0,20"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Create a new profile" Width="100" Height="30" Click="Create_Click" Margin="5,0"/>
            <Button Content="Cancel" Width="80" Height="30" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>