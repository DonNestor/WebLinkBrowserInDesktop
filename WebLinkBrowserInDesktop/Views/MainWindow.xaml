<Window x:Class="WebLinkBrowserInDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="Simple Web Browser" Height="600" Width="900">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" Margin="5">
            <Menu DockPanel.Dock="Top" Background="White">
                <MenuItem Header="Plik">
                    <MenuItem Header="_Importuj Bazę...." Click="ImportDatabase_Click">
                        <MenuItem.Icon>
                            <Image Source="https://cdn-icons-png.flaticon.com/512/2906/2906496.png" Width="16"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="_Wyjście" Click="Exit_Click" />
                </MenuItem>

                <MenuItem Header="_Edycja">
                    <MenuItem Header="_Dodaj nowy link..." Click="Add_Click" />
                </MenuItem>

                <MenuItem Header="_Pomoc">
                    <MenuItem Header="_O programie..." Click="About_Click" />
                </MenuItem>
            </Menu>

            <StackPanel DockPanel.Dock="Bottom">
                <Button Content="Dodaj Nowy" Click="Add_Click" Margin="0,5"/>
                <Button Content="Edytuj Wybrany" Click="Update_Click" Margin="0,5"/>
                <Button Content="Usuń" Click="Delete_Click" Margin="0,5" Background="#FFFFEBEB"/>
            </StackPanel>

            <ListBox x:Name="LinkListBox" SelectionChanged="LinkListBox_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <ToolBar Grid.Row="0">
                <Button Content="⬅" Click="Back_Click" ToolTip="Wstecz" Padding="5,0"/>
                <Button Content="➡" Click="Forward_Click" ToolTip="Dalej" Padding="5,0"/>
                <Button Content="🔄" Click="Reload_Click" ToolTip="Odśwież" Padding="5,0"/>
                <Separator />
                <TextBox x:Name="txtCurrentUrl" Width="400" VerticalAlignment="Center" 
                 KeyDown="txtCurrentUrl_KeyDown" Margin="5,0"/>
                <Button Content="Go" Click="Go_Click" Padding="10,0" ToolTip="Przejdź do strony"/>
                <Separator />
                <Button Content="💾" Click="SaveLink_Click" Padding="10,0" ToolTip="Zapisz link do strony"  />
                <Separator />
                <Button Click="OpenExternal_Click" ToolTip="Otwórz w domyślnej przeglądarce">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🌐" Margin="0,0,5,0"/>
                    </StackPanel>
                </Button>
            </ToolBar>

            <wv2:WebView2 x:Name="MyWebView" Grid.Row="1" Margin="5"
                  SourceChanged="MyWebView_SourceChanged"/>
        </Grid>
    </Grid>
</Window>